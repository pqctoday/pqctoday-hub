{
  "name": "pqctoday-hub",
  "private": true,
  "version": "3.5.28",
  "license": "GPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,cjs,mjs}": [
      "eslint --fix --no-error-on-unmatched-pattern",
      "prettier --write"
    ],
    "**/*.{json,md,css,html}": "prettier --write",
    "**/*.csv": "perl -pi -e 's/\\r$//'"
  },
  "scripts": {
    "predev": "cp -r node_modules/@oqs/liboqs-js/dist public/dist && mkdir -p public/wasm && (test -f public/wasm/softhsm.wasm || cp node_modules/@pqctoday/softhsm-wasm/wasm/softhsm.js node_modules/@pqctoday/softhsm-wasm/wasm/softhsm.wasm public/wasm/)",
    "dev": "vite",
    "build": "npm run build:sdk && cp -r node_modules/@oqs/liboqs-js/dist public/dist && mkdir -p public/wasm && (test -f public/wasm/softhsm.wasm || cp node_modules/@pqctoday/softhsm-wasm/wasm/softhsm.js node_modules/@pqctoday/softhsm-wasm/wasm/softhsm.wasm public/wasm/) && tsc -b && vite build && cp dist/index.html dist/404.html",
    "build:sdk": "npx esbuild src/embed/sdk.ts --bundle --outfile=public/embed/sdk.js --format=esm --target=es2020 --minify",
    "lint": "eslint --no-error-on-unmatched-pattern src e2e *.ts *.js *.cjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test e2e/accessibility.spec.ts --project=chromium",
    "test:external": "playwright test e2e/production.spec.ts e2e/compliance-sources.spec.ts",
    "coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.81",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@noble/post-quantum": "^0.6.1",
    "@oqs/liboqs-js": "^0.15.1",
    "@peculiar/asn1-schema": "^2.6.0",
    "@peculiar/asn1-x509": "^2.6.1",
    "@peculiar/asn1-x509-post-quantum": "^2.6.1",
    "@peculiar/x509": "^2.0.0",
    "@pqctoday/softhsm-wasm": "file:./src/vendor/softhsm-wasm",
    "@react-oauth/google": "^0.13.4",
    "@scure/base": "^2.0.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/file-saver": "^2.0.7",
    "@types/papaparse": "^5.5.2",
    "@xyflow/react": "^12.10.1",
    "cborg": "^5.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "ed25519-hd-key": "^1.3.0",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.27.5",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "localforage": "^1.10.0",
    "lucide-react": "^0.577.0",
    "micro-eth-signer": "^0.18.1",
    "minisearch": "^7.2.0",
    "papaparse": "^5.5.3",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-focus-lock": "^2.13.7",
    "react-ga4": "^2.1.0",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.12.0",
    "recharts": "^3.7.0",
    "reflect-metadata": "^0.2.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.17",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^27.0.0",
    "@types/lodash": "^4.17.23",
    "@types/node": "^25.6.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "axe-playwright": "^2.2.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-testing-library": "^7.16.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "lodash": "^4.17.23",
    "pdf-parse": "^2.4.5",
    "prettier": "^3.8.0",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^4.1.2"
  }
}
