# Google Analytics Measurement ID (optional — leave empty to disable tracking)
VITE_GA_MEASUREMENT_ID=

# Google OAuth Client ID for Cloud Sync (optional — leave empty to disable Google Drive sync)
# Create at: https://console.cloud.google.com/apis/credentials
# Required scope: https://www.googleapis.com/auth/drive.appdata
VITE_GOOGLE_CLIENT_ID=195420499942-266c002653363easqrcko4dtgjj2v9bm.apps.googleusercontent.com

# Base URL where pqctoday-sandbox is reachable. The Playground "Sandbox"
# category tiles iframe this origin at /embed/scenario/<id>.
# docker-compose in ~/antigravity/pqctoday-sandbox exposes it on :4000.
# Leave empty to disable the Sandbox iframe (tiles show a setup hint instead).
VITE_SANDBOX_BASE_URL=http://localhost:4000

# (Optional) Orchestrator backend that hands out per-user sandbox sessions by
# pulling GHCR images and starting containers on demand. When set, the
# Playground POSTs to {ORCHESTRATOR_URL}/sessions and uses the returned
# baseUrl for the iframe. Leave empty to use the static VITE_SANDBOX_BASE_URL.
#
# Local dev: cd ~/antigravity/pqctoday-orchestrator && npm run dev
# Then set: VITE_SANDBOX_ORCHESTRATOR_URL=http://localhost:8090
# Note: 8080 is used by OrbStack on macOS; the orchestrator defaults to 8090.
#
# Contract: see pqctoday-sandbox/docs/orchestrator-api.md
VITE_SANDBOX_ORCHESTRATOR_URL=

# NVD API key — optional but recommended for `scripts/scrape-nvd.py` and
# `scripts/apply-cpe-overrides.py`. Bumps NVD's per-IP rate limit from
# 5 req/30s to 50 req/30s. Get one at:
#   https://nvd.nist.gov/developers/request-an-api-key
# Without the key the scripts fall back to public-rate pacing.
NVD_API_KEY=
