+
+typedef struct pkcs11_kem_t pkcs11_kem_t;
+
+#include <crypto/key_exchange.h>
+
+/**
+ * Implementation of a Key Encapsulation Mechanism (KEM) using PKCS#11 
+ */
+struct pkcs11_kem_t {
+
+	/**
+	 * Implements key_exchange_t interface
